{
    "name": "Python 3",
    "image": "python:3",
    "features": {
        "ghcr.io/devcontainers/features/java": {
            "version": "11"
        }
    },
    "customizations": {
        "vscode": {
            "extensions": [
                "ms-python.python",
                "github.copilot",
                "github.copilot-chat",
                "ms-toolsai.jupyter",
                "ms-toolsai.vscode-jupyter-powertoys"
            ]
        }
    },
    "postStartCommand": "pip install -r requirements.txt"
}
