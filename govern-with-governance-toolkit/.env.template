# Microsoft Foundry project (optional — needed for LLM-powered demos)
FOUNDRY_PROJECT_ENDPOINT=https://<your-account>.services.ai.azure.com/api/projects/<your-project>
MODEL_DEPLOYMENT_NAME=gpt-4o
MODEL_API_VERSION=preview

# Governance (AGT)
GOVERNANCE_AUDIT_LOG_PATH=./logs/governance-audit.jsonl
GOVERNANCE_POLICY_DIR=./src/policies
