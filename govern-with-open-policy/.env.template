# Microsoft Foundry project (required for LLM-powered agent runs)
#
# Set FOUNDRY_PROJECT_ENDPOINT to your Foundry project endpoint URL, e.g.:
#   https://<resource-name>.cognitiveservices.azure.com/
#   https://<resource-name>.services.ai.azure.com/api/projects/<project>
#
# Auth is always Entra ID via DefaultAzureCredential — no API key needed.
# Locally: run `az login` (and ensure your account has the
# "Cognitive Services OpenAI User" role on the resource).
# In production: assign a Managed Identity with the same role.
FOUNDRY_PROJECT_ENDPOINT=https://your-resource.services.ai.azure.com/api/projects/your-project
MODEL_DEPLOYMENT_NAME=gpt-4o

# Optional Foundry metadata (used by deployment scripts / notebook 06)
FOUNDRY_SUBSCRIPTION_ID=your-subscription-id
FOUNDRY_RESOURCE_GROUP=your-resource-group
FOUNDRY_PROJECT_NAME=your-project-name

# OPA Configuration
OPA_URL=http://localhost:8181
OPA_POLICY_PATH=/v1/data

# Application Configuration
LOG_LEVEL=INFO
ENVIRONMENT=development

# Mock Data Configuration (for offline demos)
USE_MOCK_DATA=true
MOCK_DATA_PATH=./data/mock

# Agent Configuration
ENABLE_TELEMETRY=true
ENABLE_POLICY_AUDIT=true
POLICY_AUDIT_LOG_PATH=./logs/policy-audit.jsonl

# OpenTelemetry tracing (Foundry Toolkit trace viewer)
# In VS Code, run command `ai-mlstudio.tracing.open` to start the collector.
ENABLE_TRACING=false
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
