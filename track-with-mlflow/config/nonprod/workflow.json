{
    "name": "MLFlow Demo",
    "email_notifications": {
        "no_alert_for_skipped_runs": false
    },
    "webhook_notifications": {},
    "timeout_seconds": 0,
    "max_concurrent_runs": 1,
    "tasks": [
        {
            "task_key": "Ingest",
            "run_if": "ALL_SUCCESS",
            "spark_python_task": {
                "python_file": "mlflow_experiment_test/ingest.py",
                "parameters": [
                    "/dbfs/FileStore/projects/mlflow-demo"
                ],
                "source": "GIT"
            },
            "job_cluster_key": "New_job_cluster",
            "timeout_seconds": 0,
            "email_notifications": {},
            "notification_settings": {
                "no_alert_for_skipped_runs": false,
                "no_alert_for_canceled_runs": false,
                "alert_on_last_attempt": false
            },
            "webhook_notifications": {}
        },
        {
            "task_key": "Transform",
            "depends_on": [
                {
                    "task_key": "Ingest"
                }
            ],
            "run_if": "ALL_SUCCESS",
            "spark_python_task": {
                "python_file": "mlflow_experiment_test/transform.py",
                "parameters": [
                    "/dbfs/FileStore/projects/mlflow-demo/iris.csv",
                    "/dbfs/FileStore/projects/mlflow-demo"
                ],
                "source": "GIT"
            },
            "job_cluster_key": "New_job_cluster",
            "timeout_seconds": 0,
            "email_notifications": {},
            "notification_settings": {
                "no_alert_for_skipped_runs": false,
                "no_alert_for_canceled_runs": false,
                "alert_on_last_attempt": false
            },
            "webhook_notifications": {}
        },
        {
            "task_key": "Split",
            "depends_on": [
                {
                    "task_key": "Transform"
                }
            ],
            "run_if": "ALL_SUCCESS",
            "spark_python_task": {
                "python_file": "mlflow_experiment_test/split.py",
                "parameters": [
                    "/dbfs/FileStore/projects/mlflow-demo/iris_transformed.csv",
                    "/dbfs/FileStore/projects/mlflow-demo"
                ],
                "source": "GIT"
            },
            "job_cluster_key": "New_job_cluster",
            "timeout_seconds": 0,
            "email_notifications": {},
            "notification_settings": {
                "no_alert_for_skipped_runs": false,
                "no_alert_for_canceled_runs": false,
                "alert_on_last_attempt": false
            },
            "webhook_notifications": {}
        },
        {
            "task_key": "Train",
            "depends_on": [
                {
                    "task_key": "Split"
                }
            ],
            "run_if": "ALL_SUCCESS",
            "spark_python_task": {
                "python_file": "mlflow_experiment_test/train.py",
                "parameters": [
                    "/dbfs/FileStore/projects/mlflow-demo",
                    "/dbfs/FileStore/projects/mlflow-demo"
                ],
                "source": "GIT"
            },
            "job_cluster_key": "New_job_cluster",
            "timeout_seconds": 0,
            "email_notifications": {},
            "notification_settings": {
                "no_alert_for_skipped_runs": false,
                "no_alert_for_canceled_runs": false,
                "alert_on_last_attempt": false
            },
            "webhook_notifications": {}
        }
    ],
    "job_clusters": [
        {
            "job_cluster_key": "New_job_cluster",
            "new_cluster": {
                "spark_version": "13.3.x-cpu-ml-scala2.12",
                "spark_conf": {
                    "spark.databricks.cluster.profile": "singleNode",
                    "spark.master": "local[*, 4]"
                },
                "azure_attributes": {
                    "first_on_demand": 1,
                    "availability": "ON_DEMAND_AZURE",
                    "spot_bid_max_price": -1
                },
                "node_type_id": "Standard_DS3_v2",
                "driver_node_type_id": "Standard_DS3_v2",
                "custom_tags": {
                    "ResourceClass": "SingleNode"
                },
                "cluster_log_conf": {
                    "dbfs": {
                        "destination": "dbfs:/mnt/databricks-cluster-logs"
                    }
                },
                "spark_env_vars": {
                    "QUALYS_CUSTOMERID": "{{secrets/cac-aa-datalakeprod/qualys-customerid}}",
                    "CRAN_REPO": "https://cdn_team_generic_aa:${ARTIFACTORY_PWD}@artifactory.manulife.ca/artifactory/r/",
                    "QUALYS_ACTIVATIONID": "{{secrets/cac-aa-datalakeprod/qualys-activationid}}",
                    "ARTIFACTORY_PWD": "{{secrets/cac-aa-datalakeprod/aa-artifactory-api-key}}"
                },
                "enable_elastic_disk": true,
                "policy_id": "000A1693622DFCE3",
                "data_security_mode": "LEGACY_SINGLE_USER_STANDARD",
                "runtime_engine": "STANDARD",
                "num_workers": 0
            }
        }
    ],
    "git_source": {
        "git_url": "https://github.com/ani1797/mlflow-demo",
        "git_provider": "gitHub",
        "git_branch": "main"
    },
    "run_as": {
        "user_name": "aggaani@mfcgd.com"
    }
}
