# Azure Document Intelligence credentials
# Find these in the Azure Portal under your Document Intelligence resource > Keys and Endpoint

DOCUMENTINTELLIGENCE_ENDPOINT=https://<your-resource-name>.cognitiveservices.azure.com/
DOCUMENTINTELLIGENCE_API_KEY=<your-api-key>

# (Optional) Azure Blob Storage SAS URL for custom model training
# Required only for notebooks 07 (Custom Model) and 08 (Document Classifier)
DOCUMENTINTELLIGENCE_STORAGE_CONTAINER_SAS_URL=https://<storage-account>.blob.core.windows.net/<container>?<sas-token>
